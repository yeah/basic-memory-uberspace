# Public base URL of the gateway (must match the externally reachable URL,
# WITHOUT the /mcp suffix). On Uberspace: https://<username>.uber.space
BASE_URL=https://ubernaut.uber.space

# Port the gateway listens on (mapped via the Uberspace web backend).
PORT=8001

# Upstream Basic Memory MCP server (local, started as a separate service).
UPSTREAM_URL=http://127.0.0.1:8000

# Upstream WebDAV server (WsgiDAV, local, started as a separate service).
DAV_UPSTREAM_URL=http://127.0.0.1:8002

# Fixed OAuth client credentials. You choose these; enter the same values
# in the Claude / ChatGPT custom connector configuration.
CLIENT_ID=basic-memory
CLIENT_SECRET=change-me-run-openssl-rand-hex-32

# Secret used to sign the JWT access tokens. Keep this stable: changing it
# invalidates all issued access tokens and forces clients to re-authenticate.
JWT_SECRET=change-me-run-openssl-rand-hex-32

# Your login password. Used both for the OAuth /authorize browser sign-in
# AND as the WebDAV Basic Auth password.
LOGIN_PASSWORD=change-me

# Allowlist of OAuth redirect URIs (comma-separated, exact match). The
# authorization code is only ever sent to a URI listed here, which prevents an
# attacker from redirecting the flow to their own callback. REQUIRED for OAuth:
# if empty, every /authorize request is rejected.
#
# The value below is the Claude.ai connector callback. If your client uses a
# different one, the gateway logs the exact rejected redirect_uri
# (journalctl --user -u auth_gateway) — copy it here. Separate multiple URIs
# with commas, e.g. https://claude.ai/api/mcp/auth_callback,https://chatgpt.com/...
ALLOWED_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback

# WebDAV Basic Auth username. Defaults to CLIENT_ID if unset, so OAuth and
# WebDAV share one identity. Override only if you want a different DAV username.
# WEBDAV_USERNAME=basic-memory

# Basic Memory logo shown on the login page and in resource metadata.
# Referenced directly from basicmemory.com (not downloaded). Override to
# use the white variant on dark UIs, or your own URL.
# LOGO_URI=https://basicmemory.com/images/basic-memory/disk-logo-black.svg

# Optional token lifetimes (seconds). Defaults shown.
# ACCESS_TOKEN_TTL=3600
# REFRESH_TOKEN_TTL=2592000
# AUTH_CODE_TTL=300
