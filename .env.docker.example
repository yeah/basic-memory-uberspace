# ---- Docker Compose configuration ----
# Copy to .env in this directory: cp .env.docker.example .env

# Public domain. DNS must point at this host, and ports 80 + 443 must be
# reachable, so Caddy can obtain a Let's Encrypt certificate automatically.
# BASE_URL is derived from this in docker-compose.yml (https://<DOMAIN>).
DOMAIN=memory.example.com

# Fixed OAuth client credentials. You choose these; enter the same values in
# the Claude / ChatGPT / Mistral connector configuration.
# Generate the secret with: openssl rand -hex 32
CLIENT_ID=basic-memory
CLIENT_SECRET=change-me-run-openssl-rand-hex-32

# Signing key for the JWT access tokens. Keep stable across restarts (changing
# it invalidates issued access tokens). Generate with: openssl rand -hex 32
JWT_SECRET=change-me-run-openssl-rand-hex-32

# Login password: used both for the OAuth browser sign-in AND as the WebDAV
# Basic Auth password. Use a long, randomly generated value.
LOGIN_PASSWORD=change-me

# Allowed OAuth callback hosts (an https redirect URI whose host matches
# exactly is accepted). Covers Claude, ChatGPT and Mistral.
ALLOWED_REDIRECT_HOSTS=claude.ai,chatgpt.com,callback.mistral.ai

# Optional: brute-force throttle tuning (defaults shown). 0 disables.
# AUTH_FAIL_LIMIT=10
# AUTH_FAIL_WINDOW=300
